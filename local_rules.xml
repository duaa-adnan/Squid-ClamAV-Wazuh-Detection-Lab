<!--
  Custom Wazuh Rules — Local Ruleset
  =================================================
  Group 1 (100001–100003): pre-existing rules inherited from an
  earlier internship's Wazuh installation running on the same
  host — SSH brute-force detection, USB storage insertion.
  Included here for completeness since they live in the same
  local_rules.xml file; not built as part of this project.

  Group 2 (100010): custom rule built for this project, detecting
  blocked or failed requests through the Squid proxy (HTTP 403,
  502, 503) using the custom-squid-syslog decoder defined in
  local_decoder.xml. Matches directly against the raw log text
  using PCRE2 syntax rather than a named field, after running
  into Wazuh's reserved-field-name restrictions on both "status"
  and "id" during development (see project write-up, sections
  16.1 and 16.4).
-->

<group name="local,syslog,sshd,">
  <rule id="100001" level="5">
    <if_sid>5710</if_sid>
    <same_source_ip />
    <description>SSH authentication attempt from a monitored source</description>
    <mitre>
      <id>T1110</id>
    </mitre>
  </rule>

  <rule id="100002" level="10" frequency="5" timeframe="120">
    <if_matched_sid>5710</if_matched_sid>
    <same_source_ip />
    <description>SSH brute force attempt - 5+ failed logins from same source in 2 minutes</description>
    <mitre>
      <id>T1110</id>
    </mitre>
  </rule>

  <rule id="100003" level="7">
    <field name="win.system.eventID">^2003$</field>
    <field name="win.system.channel">DriverFrameworks</field>
    <description>USB storage device inserted on Windows host</description>
    <mitre>
      <id>T1091</id>
    </mitre>
  </rule>
</group>

<group name="squid,web,">
  <rule id="100010" level="10">
    <decoded_as>custom-squid-syslog</decoded_as>
    <regex type="pcre2">TCP_DENIED|TCP_MISS/50[23]|/403</regex>
    <description>Squid proxy request blocked or failed - possible malicious/unauthorized activity</description>
    <mitre>
      <id>T1071</id>
    </mitre>
  </rule>
</group>
